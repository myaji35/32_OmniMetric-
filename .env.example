# API Configuration
API_TITLE="OmniMetric API"
API_VERSION="1.0.0"
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=4

# Environment
ENVIRONMENT="development"  # development, staging, production
DEBUG=True

# Redis Configuration (for Celery & Caching)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""

# Ray Configuration (Distributed Computing)
RAY_ADDRESS="auto"
RAY_NUM_CPUS=8
RAY_OBJECT_STORE_MEMORY=2000000000  # 2GB

# Algorithm Tournament Settings
TOURNAMENT_TIMEOUT=300  # seconds (5 minutes)
TOURNAMENT_MAX_WORKERS=60
TOURNAMENT_ENABLE_GPU=False

# MLOps Auto-Retraining
MLOPS_ERROR_THRESHOLD=0.15  # 15% error triggers retraining
MLOPS_MIN_R2_SCORE=0.85
MLOPS_AUTO_RETRAIN=True
MLOPS_RETRAIN_COOLDOWN=3600  # seconds (1 hour)

# XAI Settings
XAI_ENABLE_SHAP=True
XAI_ENABLE_LIME=True
XAI_MAX_FEATURES=20

# NLG Report Settings
NLG_LANGUAGE="ko"  # ko, en
NLG_DETAIL_LEVEL="detailed"  # brief, detailed, comprehensive

# Database (Optional - for result persistence)
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="omnimetric"
DB_USER="omnimetric"
DB_PASSWORD="changeme"

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT="json"  # json, text
LOG_FILE_PATH="./logs/omnimetric.log"

# External System Integration
EXTERNAL_WEBHOOK_URL=""
EXTERNAL_API_KEY=""
